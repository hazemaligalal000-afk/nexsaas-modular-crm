{
    "name": "nexsaas/modular-core",
    "description": "NexSaaS Modular CRM/ERP/Accounting Platform - Core",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "firebase/php-jwt": "^6.10",
        "spomky-labs/otphp": "^11.0",
        "onelogin/php-saml": "^4.1",
        "league/oauth2-client": "^2.7",
        "mpdf/mpdf": "^8.2",
        "phpmailer/phpmailer": "^6.9",
        "stripe/stripe-php": "^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "giorgiosironi/eris": "^0.14"
    },
    "config": {
        "audit": {
            "abandoned": "ignore",
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    },
    "autoload": {
        "psr-4": {
            "Core\\": "core/",
            "Bootstrap\\": "bootstrap/",
            "Platform\\": "modules/Platform/",
            "CRM\\": "modules/CRM/",
            "Modules\\": "modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
