{
  "name": "Accounting",
  "version": "1.0.0",
  "dependencies": ["Platform", "ERP"],
  "permissions": [
    "accounting.coa.read",
    "accounting.coa.create",
    "accounting.coa.update",
    "accounting.coa.delete",
    "accounting.coa.merge",
    "accounting.coa.import",
    "accounting.coa.export",
    "accounting.vouchers.read",
    "accounting.vouchers.create",
    "accounting.vouchers.update",
    "accounting.vouchers.delete",
    "accounting.vouchers.submit",
    "accounting.vouchers.approve",
    "accounting.vouchers.post",
    "accounting.vouchers.reverse",
    "accounting.vouchers.import",
    "accounting.fx.read",
    "accounting.fx.manage",
    "accounting.fx.revalue",
    "accounting.ar.read",
    "accounting.ar.create",
    "accounting.ar.update",
    "accounting.ar.allocate",
    "accounting.ap.read",
    "accounting.ap.create",
    "accounting.ap.update",
    "accounting.ap.allocate",
    "accounting.bank.read",
    "accounting.bank.manage",
    "accounting.bank.reconcile",
    "accounting.cost_centers.read",
    "accounting.cost_centers.manage",
    "accounting.cost_centers.allocate",
    "accounting.assets.read",
    "accounting.assets.create",
    "accounting.assets.update",
    "accounting.assets.depreciate",
    "accounting.assets.dispose",
    "accounting.payroll.read",
    "accounting.payroll.run",
    "accounting.payroll.finalize",
    "accounting.partners.read",
    "accounting.partners.manage",
    "accounting.reports.read",
    "accounting.reports.export",
    "accounting.periods.read",
    "accounting.periods.close",
    "accounting.periods.lock"
  ],
  "routes": [
    { "method": "GET",    "path": "/api/v1/accounting/coa",                              "handler": "Accounting\\COA\\COAController::index" },
    { "method": "POST",   "path": "/api/v1/accounting/coa",                              "handler": "Accounting\\COA\\COAController::create" },
    { "method": "GET",    "path": "/api/v1/accounting/coa/{code}",                       "handler": "Accounting\\COA\\COAController::show" },
    { "method": "PUT",    "path": "/api/v1/accounting/coa/{code}",                       "handler": "Accounting\\COA\\COAController::update" },
    { "method": "POST",   "path": "/api/v1/accounting/coa/merge",                        "handler": "Accounting\\COA\\COAController::merge" },
    { "method": "POST",   "path": "/api/v1/accounting/coa/import",                       "handler": "Accounting\\COA\\COAController::import" },
    { "method": "GET",    "path": "/api/v1/accounting/coa/export",                       "handler": "Accounting\\COA\\COAController::export" },
    { "method": "GET",    "path": "/api/v1/accounting/vouchers",                         "handler": "Accounting\\Vouchers\\VoucherController::index" },
    { "method": "POST",   "path": "/api/v1/accounting/vouchers",                         "handler": "Accounting\\Vouchers\\VoucherController::save" },
    { "method": "GET",    "path": "/api/v1/accounting/vouchers/{id}",                    "handler": "Accounting\\Vouchers\\VoucherController::show" },
    { "method": "PUT",    "path": "/api/v1/accounting/vouchers/{id}",                    "handler": "Accounting\\Vouchers\\VoucherController::update" },
    { "method": "POST",   "path": "/api/v1/accounting/vouchers/{id}/submit",             "handler": "Accounting\\Vouchers\\VoucherController::submit" },
    { "method": "POST",   "path": "/api/v1/accounting/vouchers/{id}/approve",            "handler": "Accounting\\Vouchers\\VoucherController::approve" },
    { "method": "POST",   "path": "/api/v1/accounting/vouchers/{id}/post",               "handler": "Accounting\\Vouchers\\VoucherController::post" },
    { "method": "POST",   "path": "/api/v1/accounting/vouchers/{id}/reverse",            "handler": "Accounting\\Vouchers\\VoucherController::reverse" },
    { "method": "POST",   "path": "/api/v1/accounting/vouchers/import",                  "handler": "Accounting\\Vouchers\\VoucherController::import" },
    { "method": "GET",    "path": "/api/v1/accounting/vouchers/{id}/pdf",                "handler": "Accounting\\Vouchers\\VoucherController::pdf" },
    { "method": "GET",    "path": "/api/v1/accounting/fx/rates",                         "handler": "Accounting\\FX\\FXController::index" },
    { "method": "POST",   "path": "/api/v1/accounting/fx/rates",                         "handler": "Accounting\\FX\\FXController::store" },
    { "method": "GET",    "path": "/api/v1/accounting/fx/rates/{currency}/{date}",       "handler": "Accounting\\FX\\FXController::getRate" },
    { "method": "POST",   "path": "/api/v1/accounting/fx/revalue",                       "handler": "Accounting\\FX\\FXController::revalue" },
    { "method": "GET",    "path": "/api/v1/accounting/ar/invoices",                      "handler": "Accounting\\AR\\ARController::index" },
    { "method": "POST",   "path": "/api/v1/accounting/ar/invoices",                      "handler": "Accounting\\AR\\ARController::create" },
    { "method": "POST",   "path": "/api/v1/accounting/ar/invoices/{id}/payments",        "handler": "Accounting\\AR\\ARController::recordPayment" },
    { "method": "GET",    "path": "/api/v1/accounting/ar/aging",                         "handler": "Accounting\\AR\\ARController::aging" },
    { "method": "GET",    "path": "/api/v1/accounting/ap/bills",                         "handler": "Accounting\\AP\\APController::index" },
    { "method": "POST",   "path": "/api/v1/accounting/ap/bills",                         "handler": "Accounting\\AP\\APController::create" },
    { "method": "POST",   "path": "/api/v1/accounting/ap/bills/{id}/payments",           "handler": "Accounting\\AP\\APController::recordPayment" },
    { "method": "GET",    "path": "/api/v1/accounting/ap/aging",                         "handler": "Accounting\\AP\\APController::aging" },
    { "method": "GET",    "path": "/api/v1/accounting/bank/accounts",                    "handler": "Accounting\\Bank\\BankController::index" },
    { "method": "POST",   "path": "/api/v1/accounting/bank/accounts/{id}/reconcile",     "handler": "Accounting\\Bank\\BankController::reconcile" },
    { "method": "POST",   "path": "/api/v1/accounting/bank/accounts/{id}/import",        "handler": "Accounting\\Bank\\BankController::importStatement" },
    { "method": "GET",    "path": "/api/v1/accounting/cost-centers",                     "handler": "Accounting\\CostCenters\\CostCenterController::index" },
    { "method": "POST",   "path": "/api/v1/accounting/cost-centers",                     "handler": "Accounting\\CostCenters\\CostCenterController::create" },
    { "method": "GET",    "path": "/api/v1/accounting/assets",                           "handler": "Accounting\\Assets\\AssetController::index" },
    { "method": "POST",   "path": "/api/v1/accounting/assets",                           "handler": "Accounting\\Assets\\AssetController::create" },
    { "method": "POST",   "path": "/api/v1/accounting/assets/{id}/depreciate",           "handler": "Accounting\\Assets\\AssetController::depreciate" },
    { "method": "POST",   "path": "/api/v1/accounting/assets/{id}/dispose",              "handler": "Accounting\\Assets\\AssetController::dispose" },
    { "method": "GET",    "path": "/api/v1/accounting/payroll/runs",                     "handler": "Accounting\\Payroll\\PayrollController::index" },
    { "method": "POST",   "path": "/api/v1/accounting/payroll/runs",                     "handler": "Accounting\\Payroll\\PayrollController::run" },
    { "method": "POST",   "path": "/api/v1/accounting/payroll/runs/{id}/finalize",       "handler": "Accounting\\Payroll\\PayrollController::finalize" },
    { "method": "GET",    "path": "/api/v1/accounting/reports/trial-balance",            "handler": "Accounting\\Reports\\ReportController::trialBalance" },
    { "method": "GET",    "path": "/api/v1/accounting/reports/income-statement",         "handler": "Accounting\\Reports\\ReportController::incomeStatement" },
    { "method": "GET",    "path": "/api/v1/accounting/reports/balance-sheet",            "handler": "Accounting\\Reports\\ReportController::balanceSheet" },
    { "method": "GET",    "path": "/api/v1/accounting/periods",                          "handler": "Accounting\\Periods\\PeriodController::index" },
    { "method": "POST",   "path": "/api/v1/accounting/periods/{period}/close",           "handler": "Accounting\\Periods\\PeriodController::close" },
    { "method": "POST",   "path": "/api/v1/accounting/periods/{period}/lock",            "handler": "Accounting\\Periods\\PeriodController::lock" }
  ]
}
