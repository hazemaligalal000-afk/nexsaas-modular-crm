{
  "name": "ERP",
  "version": "1.0.0",
  "dependencies": ["Platform"],
  "permissions": [
    "erp.gl.read",
    "erp.gl.post",
    "erp.gl.close_period",
    "erp.invoices.read",
    "erp.invoices.create",
    "erp.invoices.update",
    "erp.invoices.delete",
    "erp.invoices.finalize",
    "erp.payments.read",
    "erp.payments.create",
    "erp.expenses.read",
    "erp.expenses.create",
    "erp.expenses.approve",
    "erp.purchase_orders.read",
    "erp.purchase_orders.create",
    "erp.purchase_orders.approve",
    "erp.inventory.read",
    "erp.inventory.create",
    "erp.inventory.update",
    "erp.inventory.adjust",
    "erp.warehouses.read",
    "erp.warehouses.manage",
    "erp.hr.employees.read",
    "erp.hr.employees.create",
    "erp.hr.employees.update",
    "erp.hr.employees.delete",
    "erp.hr.leave.read",
    "erp.hr.leave.request",
    "erp.hr.leave.approve",
    "erp.payroll.read",
    "erp.payroll.run",
    "erp.payroll.finalize",
    "erp.projects.read",
    "erp.projects.create",
    "erp.projects.update",
    "erp.projects.delete",
    "erp.manufacturing.bom.read",
    "erp.manufacturing.bom.create",
    "erp.manufacturing.work_orders.read",
    "erp.manufacturing.work_orders.create",
    "erp.manufacturing.work_orders.complete",
    "erp.reports.read"
  ],
  "routes": [
    { "method": "GET",    "path": "/api/v1/erp/gl/journal-entries",              "handler": "ERP\\GL\\JournalEntryController::index" },
    { "method": "POST",   "path": "/api/v1/erp/gl/journal-entries",              "handler": "ERP\\GL\\JournalEntryController::post" },
    { "method": "GET",    "path": "/api/v1/erp/gl/trial-balance",                "handler": "ERP\\GL\\TrialBalanceController::generate" },
    { "method": "GET",    "path": "/api/v1/erp/gl/financial-statements",         "handler": "ERP\\GL\\FinancialStatementController::generate" },
    { "method": "POST",   "path": "/api/v1/erp/gl/periods/{period}/close",       "handler": "ERP\\GL\\FinPeriodController::close" },
    { "method": "GET",    "path": "/api/v1/erp/invoices",                        "handler": "ERP\\Invoicing\\InvoiceController::index" },
    { "method": "POST",   "path": "/api/v1/erp/invoices",                        "handler": "ERP\\Invoicing\\InvoiceController::create" },
    { "method": "GET",    "path": "/api/v1/erp/invoices/{id}",                   "handler": "ERP\\Invoicing\\InvoiceController::show" },
    { "method": "PUT",    "path": "/api/v1/erp/invoices/{id}",                   "handler": "ERP\\Invoicing\\InvoiceController::update" },
    { "method": "POST",   "path": "/api/v1/erp/invoices/{id}/finalize",          "handler": "ERP\\Invoicing\\InvoiceController::finalize" },
    { "method": "POST",   "path": "/api/v1/erp/invoices/{id}/payments",          "handler": "ERP\\Invoicing\\InvoiceController::recordPayment" },
    { "method": "POST",   "path": "/api/v1/billing/stripe/webhook",              "handler": "ERP\\Invoicing\\StripeWebhookController::handle" },
    { "method": "GET",    "path": "/api/v1/erp/inventory/items",                 "handler": "ERP\\Inventory\\InventoryController::index" },
    { "method": "POST",   "path": "/api/v1/erp/inventory/items",                 "handler": "ERP\\Inventory\\InventoryController::create" },
    { "method": "POST",   "path": "/api/v1/erp/inventory/movements",             "handler": "ERP\\Inventory\\InventoryController::recordMovement" },
    { "method": "GET",    "path": "/api/v1/erp/hr/employees",                    "handler": "ERP\\HR\\EmployeeController::index" },
    { "method": "POST",   "path": "/api/v1/erp/hr/employees",                    "handler": "ERP\\HR\\EmployeeController::create" },
    { "method": "GET",    "path": "/api/v1/erp/hr/employees/{id}",               "handler": "ERP\\HR\\EmployeeController::show" },
    { "method": "PUT",    "path": "/api/v1/erp/hr/employees/{id}",               "handler": "ERP\\HR\\EmployeeController::update" },
    { "method": "GET",    "path": "/api/v1/erp/hr/leave-requests",               "handler": "ERP\\HR\\LeaveController::index" },
    { "method": "POST",   "path": "/api/v1/erp/hr/leave-requests",               "handler": "ERP\\HR\\LeaveController::create" },
    { "method": "PUT",    "path": "/api/v1/erp/hr/leave-requests/{id}/approve",  "handler": "ERP\\HR\\LeaveController::approve" },
    { "method": "GET",    "path": "/api/v1/erp/payroll/runs",                    "handler": "ERP\\HR\\PayrollController::index" },
    { "method": "POST",   "path": "/api/v1/erp/payroll/runs",                    "handler": "ERP\\HR\\PayrollController::run" },
    { "method": "POST",   "path": "/api/v1/erp/payroll/runs/{id}/finalize",      "handler": "ERP\\HR\\PayrollController::finalize" },
    { "method": "GET",    "path": "/api/v1/erp/projects",                        "handler": "ERP\\Projects\\ProjectController::index" },
    { "method": "POST",   "path": "/api/v1/erp/projects",                        "handler": "ERP\\Projects\\ProjectController::create" },
    { "method": "GET",    "path": "/api/v1/erp/projects/{id}",                   "handler": "ERP\\Projects\\ProjectController::show" },
    { "method": "PUT",    "path": "/api/v1/erp/projects/{id}",                   "handler": "ERP\\Projects\\ProjectController::update" },
    { "method": "GET",    "path": "/api/v1/erp/manufacturing/boms",              "handler": "ERP\\Manufacturing\\BOMController::index" },
    { "method": "POST",   "path": "/api/v1/erp/manufacturing/boms",              "handler": "ERP\\Manufacturing\\BOMController::create" },
    { "method": "GET",    "path": "/api/v1/erp/manufacturing/work-orders",       "handler": "ERP\\Manufacturing\\WorkOrderController::index" },
    { "method": "POST",   "path": "/api/v1/erp/manufacturing/work-orders",       "handler": "ERP\\Manufacturing\\WorkOrderController::create" },
    { "method": "POST",   "path": "/api/v1/erp/manufacturing/work-orders/{id}/complete", "handler": "ERP\\Manufacturing\\WorkOrderController::complete" }
  ]
}
