{
  "name": "Platform",
  "version": "1.0.0",
  "dependencies": [],
  "permissions": [
    "platform.auth.login",
    "platform.auth.logout",
    "platform.auth.refresh",
    "platform.auth.2fa.enroll",
    "platform.auth.2fa.verify",
    "platform.auth.sso.connect",
    "platform.users.read",
    "platform.users.create",
    "platform.users.update",
    "platform.users.delete",
    "platform.roles.read",
    "platform.roles.assign",
    "platform.roles.revoke",
    "platform.permissions.read",
    "platform.permissions.assign",
    "platform.permissions.revoke",
    "platform.audit_log.read",
    "platform.webhooks.read",
    "platform.webhooks.create",
    "platform.webhooks.update",
    "platform.webhooks.delete",
    "platform.billing.read",
    "platform.billing.manage",
    "platform.search.global"
  ],
  "routes": [
    { "method": "POST",   "path": "/api/v1/auth/login",                        "handler": "Platform\\Auth\\AuthController::login" },
    { "method": "POST",   "path": "/api/v1/auth/logout",                       "handler": "Platform\\Auth\\AuthController::logout" },
    { "method": "POST",   "path": "/api/v1/auth/refresh",                      "handler": "Platform\\Auth\\AuthController::refresh" },
    { "method": "POST",   "path": "/api/v1/auth/2fa/enroll",                   "handler": "Platform\\Auth\\AuthController::enroll2fa" },
    { "method": "POST",   "path": "/api/v1/auth/2fa/verify",                   "handler": "Platform\\Auth\\AuthController::verify2fa" },
    { "method": "GET",    "path": "/api/v1/auth/sso/{provider}",               "handler": "Platform\\Auth\\SSOController::redirect" },
    { "method": "POST",   "path": "/api/v1/auth/sso/{provider}/callback",      "handler": "Platform\\Auth\\SSOController::callback" },
    { "method": "GET",    "path": "/api/v1/platform/users",                    "handler": "Platform\\Users\\UserController::index" },
    { "method": "POST",   "path": "/api/v1/platform/users",                    "handler": "Platform\\Users\\UserController::create" },
    { "method": "GET",    "path": "/api/v1/platform/users/{id}",               "handler": "Platform\\Users\\UserController::show" },
    { "method": "PUT",    "path": "/api/v1/platform/users/{id}",               "handler": "Platform\\Users\\UserController::update" },
    { "method": "DELETE", "path": "/api/v1/platform/users/{id}",               "handler": "Platform\\Users\\UserController::delete" },
    { "method": "PUT",    "path": "/api/v1/platform/roles/{role}/permissions", "handler": "Platform\\RBAC\\RBACController::updatePermissions" },
    { "method": "GET",    "path": "/api/v1/platform/audit-log",                "handler": "Platform\\Audit\\AuditController::index" },
    { "method": "GET",    "path": "/api/v1/platform/search",                   "handler": "Platform\\Search\\SearchController::global" }
  ]
}
