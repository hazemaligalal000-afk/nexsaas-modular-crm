#!/bin/bash
# .git/hooks/commit-msg (Requirement 9.190 - Enterprise Quality Enforcement)
# Validates commit messages follow Conventional Commits (feat, fix, docs, style, refactor, perf, test, build, ci, chore)

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat $COMMIT_MSG_FILE)

# Conventional Commits regex
CONVENTIONAL_REG="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9_-]+\))?!?: .+$"

if [[ ! $COMMIT_MSG =~ $CONVENTIONAL_REG ]]; then
    echo -e "\033[31m[ERROR] Invalid commit message format!\033[0m"
    echo -e "NexSaaS mandates \033[32mConventional Commits\033[0m (Requirement 9.190)."
    echo -e "Format: \033[36mtype(scope): description\033[0m"
    echo -e "Example: \033[36mfeat(auth): add google oauth provider\033[0m"
    echo -e "Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
    exit 1
fi
