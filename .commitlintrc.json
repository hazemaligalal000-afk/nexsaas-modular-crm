{
    "extends": ["@commitlint/config-conventional"],
    "rules": {
        "type-enum": [
            2,
            "always",
            [
                "feat",
                "fix",
                "docs",
                "style",
                "refactor",
                "perf",
                "test",
                "build",
                "ci",
                "chore",
                "revert",
                "sec"
            ]
        ],
        "subject-full-stop": [2, "never", "."],
        "subject-case": [0, "always", "lower-case"]
    }
}
