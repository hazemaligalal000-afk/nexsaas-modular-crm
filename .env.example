APP_ENV=local

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexsaas
DB_USER=nexsaas
DB_PASSWORD=secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=secret

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=nexsaas
RABBITMQ_PASSWORD=secret
RABBITMQ_VHOST=nexsaas

# JWT (RS256 — generate with: openssl genrsa -out jwt_private.pem 2048)
JWT_PRIVATE_KEY_PATH=storage/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=storage/keys/jwt_public.pem
JWT_ACCESS_TTL=900        # 15 minutes
JWT_REFRESH_TTL=604800    # 7 days

# AI Engine
AI_ENGINE_URL=http://fastapi:8000
